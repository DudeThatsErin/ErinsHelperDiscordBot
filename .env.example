# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Google Custom Search API Configuration (for SpongeBob image search)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id_here

# Microsoft Graph / OneNote Integration
# Register an app at https://portal.azure.com -> Azure Active Directory -> App registrations
# Required API permissions: Notes.Create, Notes.ReadWrite (Delegated)
# Add a redirect URI matching MS_REDIRECT_URI under Authentication -> Web
MS_CLIENT_ID=your_azure_app_client_id
MS_CLIENT_SECRET=your_azure_app_client_secret
MS_REDIRECT_URI=http://localhost:3636/auth/callback
MS_CALLBACK_PORT=3636
